# Plantilla de variables de entorno para el entorno test.
# Copia este archivo como .env y rellena los valores reales.
# NUNCA versiones .env — está en .gitignore.

APP_ENV=test
APP_TESTING=1

# Cadena de conexión a PostgreSQL local.
# Formato: postgresql://<usuario>:<contraseña>@<host>:<puerto>/<base_de_datos>
DATABASE_URL=postgresql://app_user:<contraseña>@localhost:5432/apiflask

# Strings aleatorios de al menos 32 caracteres.
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=<reemplazar>
APP_SECURITY_PASSWORD_SALT=<reemplazar>

# Opcional: carga datos semilla al arrancar (útil para demos).
# APP_SEED_DATA=1
